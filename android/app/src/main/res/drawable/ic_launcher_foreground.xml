<!--
  FOREGROUND LAYER — adaptive icon (108×108dp canvas, safe zone ~18–90dp)
  Ganti file ini dengan logo asli project baru.
  Semua elemen putih agar kontras di atas background brand color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Rocket body + nose cone -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,20 L68,52 L68,74 Q68,78 64,78 L44,78 Q40,78 40,74 L40,52 Z" />

    <!-- Left fin -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,62 L28,78 L40,78 Z" />

    <!-- Right fin -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M68,62 L80,78 L68,78 Z" />

    <!-- Porthole window — ring only, brand-color background shows through -->
